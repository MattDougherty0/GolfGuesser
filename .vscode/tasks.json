{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "dev",
      "type": "shell",
      "command": "npm run dev",
      "isBackground": true,
      "problemMatcher": {
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Ready in|compiled|Local:"
        }
      },
      "presentation": { "reveal": "always", "panel": "new" }
    },
    {
      "label": "preview",
      "type": "shell",
      "command": "sleep 4 && open http://localhost:3000",
      "dependsOn": "dev",
      "dependsOrder": "sequence",
      "presentation": { "reveal": "silent" }
    },
    {
      "label": "dev and preview",
      "dependsOn": ["dev", "preview"],
      "dependsOrder": "sequence"
    }
  ]
}
